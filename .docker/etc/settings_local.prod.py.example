###
#
# Email Configuration
#
# Reads SMTP credentials from the environment (e.g. a Hostinger mailbox for
# waisf.org) rather than hardcoding them here — set EMAIL_HOST/EMAIL_HOST_USER/
# EMAIL_HOST_PASSWORD as real env vars (or in an untracked .env loaded before
# this file) on the production host. Falls back to the console backend (safe
# default — prints emails to the server log instead of sending them) if
# EMAIL_HOST isn't set, so an incomplete config fails safe rather than
# silently trying to send through an unconfigured relay.
#
###
DEFAULT_FROM_EMAIL = os.environ.get('DEFAULT_FROM_EMAIL', 'noreply@waisf.org')
if os.environ.get('EMAIL_HOST'):
    EMAIL_BACKEND = 'django.core.mail.backends.smtp.EmailBackend'
    EMAIL_HOST = os.environ.get('EMAIL_HOST')
    EMAIL_PORT = int(os.environ.get('EMAIL_PORT', 587))
    EMAIL_HOST_USER = os.environ.get('EMAIL_HOST_USER', '')
    EMAIL_HOST_PASSWORD = os.environ.get('EMAIL_HOST_PASSWORD', '')
    EMAIL_USE_TLS = os.environ.get('EMAIL_USE_TLS', 'True') == 'True'
    EMAIL_USE_SSL = os.environ.get('EMAIL_USE_SSL', 'False') == 'True'
else:
    EMAIL_BACKEND = 'django.core.mail.backends.console.EmailBackend'


###
#
# Celery Asynchronous Task Processing (Optional)
#
###
# Using dedicated Celery workers for asynchronous tasks (required e.g. for asynchronous batch badge-awarding)
# Set to True to run celery tasks in same thread as webserver (True means that asynchronous processing is OFF)
CELERY_ALWAYS_EAGER = False

CELERY_BROKER_URL = 'redis://redis:6379/0'
CELERY_RESULT_BACKEND = 'redis://redis:6379/0'


###
#
# Application Options Configuration
#
###
# This is where the Django backend itself is reachable — a separate
# subdomain from the Angular UI's own cert.waisf.org (both want to own the
# exact same /public/assertions/:slug path, which can't cleanly coexist on
# one origin). Django's own content-negotiation redirect (BadgrApp.
# public_pages_redirect) sends browsers over to cert.waisf.org.
HTTP_ORIGIN = 'https://api.cert.waisf.org'
# SECURITY WARNING: '*' accepts any Host header and must NEVER be used in a
# real deployment (Host header injection: cache poisoning, password-reset
# link poisoning, etc). This example deliberately ships a non-working
# placeholder instead of '*' so a copy-paste deploy fails loudly instead of
# silently running wide open — replace with your real domain(s), e.g.
# ALLOWED_HOSTS = ['api.cert.waisf.org'].
ALLOWED_HOSTS = ['REPLACE_WITH_YOUR_REAL_DOMAIN']
STATIC_URL = HTTP_ORIGIN + '/static/'

# The Angular UI lives on a different origin (cert.waisf.org) than this API
# (api.cert.waisf.org) in production, so its browser XHR calls need CORS.
CORS_ALLOWED_ORIGINS = ['https://cert.waisf.org']
CSRF_COOKIE_DOMAIN = ''
CSRF_TRUSTED_ORIGINS = ['https://cert.waisf.org']


# Optionally restrict issuer creation to accounts that have the 'issuer.add_issuer' permission
BADGR_APPROVED_ISSUERS_ONLY = False

# Automatically send an email the first time that recipient identifier (email type) has been used on the system.
GDPR_COMPLIANCE_NOTIFY_ON_FIRST_AWARD = True

SECRET_KEY = ''.join(random.choice(string.ascii_uppercase + string.digits) for _ in range(40))
UNSUBSCRIBE_KEY = ''.join(random.choice(string.ascii_uppercase + string.digits) for _ in range(40))
UNSUBSCRIBE_SECRET_KEY = str(SECRET_KEY)


